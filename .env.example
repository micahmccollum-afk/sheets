# Firebase Firestore - required for data storage
# See FIREBASE_SETUP.md for how to get these values

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Use base64-encoded private key (recommended) or FIREBASE_PRIVATE_KEY with raw key
FIREBASE_PRIVATE_KEY_BASE64=your-base64-encoded-private-key
